# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Anthropic API key — powers the agent pipeline (research/extraction/validation/analysis).
# Obtain one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SEC EDGAR requires a descriptive User-Agent identifying you and a contact email.
# No signup needed — see https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_USER_AGENT=FinAnalysis research agent your-email@example.com
